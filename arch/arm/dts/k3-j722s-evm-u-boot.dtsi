#include "k3-j722s-binman.dtsi"

/ {
	chosen {
		stdout-path = "serial2:115200n8";
		tick-timer = &main_timer0;
	};
};

&dmsc {
	bootph-pre-ram;
};

&main_bcdma {
	bootph-pre-ram;
};

&ospi0 {
	flash@0 {
		spi-max-frequency = <25000000>;
	};

	nand@0 {
		spi-max-frequency = <25000000>;
	};
};
